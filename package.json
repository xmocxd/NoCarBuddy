{
  "name": "nocarbuddy",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "start": "concurrently \"npm run dev\" \"npm run server-dev\"",
    "start:prod": "node server/server.js",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/server.js",
    "server-dev": "nodemon -L server/server.js",
    "test": "npm run test:client && npm --prefix server run test",
    "test:client": "vitest run",
    "test:client:watch": "vitest",
    "test:all": "npm test",
    "fix-rollup": "rm -rf node_modules && npm i && cd server && rm -rf node_modules && npm i && cd .. && npm run build"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "leaflet": "^1.9.4",
    "nosleep.js": "^0.12.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.1.1",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.4",
    "concurrently": "^9.2.1",
    "cookie-parser": "~1.4.7",
    "cors": "^2.8.4",
    "debug": "^2.6.9",
    "express": "^4.22.1",
    "express-winston": "^4.2.0",
    "jsdom": "^29.0.1",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.23",
    "nodemon": "^3.1.9",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.10.0",
    "serve-favicon": "^2.5.0",
    "tailwindcss": "^4.1.17",
    "vite": "^7.2.6",
    "vitest": "^4.1.2",
    "winston": "^3.18.3"
  }
}
